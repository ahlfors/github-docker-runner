# ============================================
# GitHub 认证（必填）
# ============================================
# 创建 PAT: https://github.com/settings/tokens
# 所需权限: repo (all), admin:org (all), workflow
ACCESS_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 组织级 Runner 配置
ORG_NAME=your-org-name

# 仓库级 Runner 配置（与组织级二选一）
# REPO_URL=https://github.com/your-user/your-repo

# ============================================
# Runner 配置（可选）
# ============================================
RUNNER_NAME_PREFIX=prod-runner
RUNNER_LABELS=self-hosted,linux,x64,docker
RUNNER_GROUP=Default